// datasource and generator
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  body      String
  status    MessageStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}
